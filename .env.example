# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=forgetting_machine          # database name created on first run
POSTGRES_USER=fm_user                   # postgres superuser for the DB
POSTGRES_PASSWORD=changeme_strong_pw    # must be set; never use default in prod
DATABASE_URL=postgresql://fm_user:changeme_strong_pw@postgres:5432/forgetting_machine

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379            # used by BullMQ workers and context cache

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development                    # set to "production" in prod

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_YOUR_CLERK_SECRET_KEY
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY

# ─── Ollama ───────────────────────────────────────────────────────────────────
# Run Ollama on the host; containers reach it via host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=llama3.2               # used for scoring and expansion LLM calls
OLLAMA_EMBED_MODEL=nomic-embed-text     # produces 768-dim vectors (pull with: ollama pull nomic-embed-text)

# ─── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@forgetting-machine.app

# ─── Rate Limits ──────────────────────────────────────────────────────────────
MAX_INGESTS_PER_DAY=100                 # per-user ingest cap
MAX_ENTRIES_FREE_TIER=500              # total entry cap for free accounts

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# These are picked up by the Vite dev server; copy to frontend/.env
VITE_API_URL=http://localhost:3000
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_CLERK_PUBLISHABLE_KEY
VITE_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
