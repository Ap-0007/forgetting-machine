    "ioredis": "^5.11.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.21.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "@types/web-push": "^3.6.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
